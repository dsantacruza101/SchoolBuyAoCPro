# Firebase Configuration
# Copy this file to .env and fill in your values from the Firebase console
# Never commit .env to version control

NG_APP_FIREBASE_API_KEY=your_api_key_here
NG_APP_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NG_APP_FIREBASE_PROJECT_ID=your_project_id
NG_APP_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NG_APP_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NG_APP_FIREBASE_APP_ID=your_app_id
